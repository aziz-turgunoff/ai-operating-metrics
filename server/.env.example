# Copy to .env — never commit the real file.

PORT=8787

# SQLite for local dev. Swap to a Postgres URL for production
# (see prisma/schema.prisma header for the migration steps).
DATABASE_URL="file:./dev.db"

# --- OpenRouter (LLM gateway usage) ---
# OPENROUTER_KEY      -> GET /auth/key   (live totals + credit balance; any key works)
# OPENROUTER_MGMT_KEY -> GET /activity   (per-model breakdown; ORG MANAGEMENT KEY REQUIRED)
# Without OPENROUTER_MGMT_KEY, totals/spend still go live (from /auth/key) but
# per-model analytics stays pending.
OPENROUTER_KEY=
OPENROUTER_MGMT_KEY=

# --- Open WebUI gateway ---
OPENWEBUI_URL=https://oi.apollosoftwareservices.com
OPENWEBUI_TOKEN=
# Best-guess default — confirm the real analytics route from the admin panel's
# Network tab and override here if it differs.
OPENWEBUI_ANALYTICS_PATH=/api/v1/analytics

# --- Company AI fallback (Source C, TEMPORARY — see connectors/companyai.js) ---
# Reuses OPENWEBUI_URL/OPENWEBUI_TOKEN above. Only used for Business Impact
# metrics while LeadBank/Apollo (Source B) are still pending real keys.
OPENWEBUI_CHAT_COMPLETIONS_PATH=/api/chat/completions
# The model id with leadbank_bi/apollo tools attached — no default on purpose;
# this connector stays pending until you set the real model.
OPENWEBUI_COMPANYAI_MODEL=

# --- LeadBank BI ---
# Known bug: date-range params error; we use days= lookback instead.
LEADBANK_URL=
LEADBANK_KEY=
LEADBANK_DAYS=30

# --- Apollo ERP ---
# Known bug: raw revenue endpoint returns NodeApiError intermittently — we
# retry once, then fall back to the last-good in-memory response if needed.
APOLLO_URL=
APOLLO_KEY=
# Which membership query to report: "agent" (agent-level) or "department".
# The two return different totals — pick the one the team wants as source of truth.
APOLLO_MEMBERSHIP_SCOPE=agent

# --- Qdrant --- (was blocked on XTR/Dmitrii whitelist)
QDRANT_URL=
QDRANT_API_KEY=

# --- Fireflies ---
FIREFLIES_API_KEY=

# --- CI/CD (Engineering Squad admin panel) ---
CICD_PROVIDER=github
CICD_TOKEN=
CICD_GITHUB_REPO=org/repo

# --- n8n / Zapier --- (no owner yet as of 2026-07-08 risk log)
N8N_URL=
N8N_API_KEY=

# --- Derived formula ---
# Locked 2026-07-08: $20/hr loaded rate.
HOURS_SAVED_RATE_USD_PER_HOUR=20
# NOT locked yet — leave unset until the team signs off; hours_saved/cost_savings
# stay "pending" until this exists.
AVG_MINUTES_SAVED_PER_TASK=
