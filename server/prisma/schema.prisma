// Moved from local SQLite to a hosted Postgres (Neon, via Vercel's
// marketplace integration) on 2026-07-11 so serverless functions on Vercel
// have a real persistent DB — a SQLite file doesn't survive between
// stateless function invocations. Local dev points DATABASE_URL at the same
// Neon instance (see server/.env); no separate local DB needed.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for runtime queries (serverless functions open/close a
  // connection per invocation, so pooling matters). Migrations use the direct
  // (unpooled) URL instead — Neon's PgBouncer-style pooler doesn't reliably
  // support the advisory locks Prisma's migration engine needs.
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// One row per snapshot run (manual or monthly cron). Keeps the raw payload
// from every connector so nothing is lost even if the metric mapping changes later.
model Snapshot {
  id          Int           @id @default(autoincrement())
  month       String // "2026-07"
  capturedAt  DateTime      @default(now())
  raw         String // JSON.stringify of { sources: {...} } as returned by connectors
  metrics     MetricValue[]
}

// One row per individual metric value in a snapshot — normalized so the
// frontend can query a single metric's history over time without parsing raw JSON.
model MetricValue {
  id           Int      @id @default(autoincrement())
  snapshotId   Int
  snapshot     Snapshot @relation(fields: [snapshotId], references: [id])
  category     String // "northStar" | category name e.g. "AI Adoption"
  metricKey    String // e.g. "hours_saved"
  label        String
  value        Float?
  valueText    String? // for non-numeric values (e.g. "10.5%") if needed
  unit         String?
  source       String
  sourceStatus String // "live" | "pending" | "mock" | "error"

  @@index([metricKey, snapshotId])
}
